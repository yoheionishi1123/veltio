PORT=3210
CVR_STORAGE_DIR=/app/server
SESSION_COOKIE_NAME=cvr_sid

# Auth provider: local or supabase
AUTH_PROVIDER=local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for GA4 OAuth
GA4_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GA4_OAUTH_CLIENT_SECRET=your-client-secret
GA4_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/ga4/oauth/callback

# Optional for production email verification
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Veltio <no-reply@your-domain.example.com>

# Optional for operator admin console
ADMIN_EMAILS=owner@example.com

# Optional for Veltio self analytics sync in admin
SELF_GA4_PROPERTY_ID=123456789
SELF_GA4_MEASUREMENT_ID=G-VBKYWDLGE5
SELF_GA4_STREAM_ID=14131607973
SELF_GA4_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
SELF_GA4_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
